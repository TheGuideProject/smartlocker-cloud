# SmartLocker Cloud - Environment Variables
# Copy this to .env and fill in your values

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@localhost:5432/smartlocker

# Security
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
ALGORITHM=HS256

# Admin credentials (created on first startup)
ADMIN_EMAIL=admin@ppg.com
ADMIN_PASSWORD=changeme123

# Environment
ENVIRONMENT=development

# Upload directory for PDFs
UPLOAD_DIR=uploads
